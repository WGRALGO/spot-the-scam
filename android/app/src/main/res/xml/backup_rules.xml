<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy backup config (Android 11 and below).
  Nothing is eligible for backup; the app keeps no off-device data.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
